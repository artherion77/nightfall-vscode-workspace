{
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:0.33.0"
			]
		},
		"nightfall": {
			"type": "stdio",
			"command": "${workspaceFolder}/../nightfall-mcp/.venv/bin/python",
			"args": [
				"${workspaceFolder}/../nightfall-mcp/nightfall_mcp_server.py"
			]
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}